m4_include(testsuite.inc)

AT_INIT

# -----------------------------------------------------------------------

m4_pushdef([DICOD_TEST],[dicod -L $abs_builddir/.. --runtest greek_kbd])

AT_BANNER([Module greek_kbd])

AT_SETUP([Basic translation])
AT_KEYWORDS([basic])

AT_CHECK([DICOD_TEST abcdefghijklmnopqrstuvwxyz ABCDEFGHIJKLMNOPQRSTUVWXYZ],
[0],
[abcdefghijklmnopqrstuvwxyz: αβψδεφγηιξκλμνοπ·ρστθωςχυζ
ABCDEFGHIJKLMNOPQRSTUVWXYZ: ΑΒΨΔΕΦΓΗΙΞΚΛΜΝΟΠ―ΡΣΤΘΩΣΧΥΖ
])
AT_CLEANUP

AT_SETUP([Diacritics])
AT_KEYWORDS([diacritics])
AT_CHECK([DICOD_TEST "a'e'i'i:i:'o'y'y:y:'v'" "A'E'I'I:I:'O'Y'Y:Y:'V'"],
[0],
[a'e'i'i:i:'o'y'y:y:'v': άέίϊΐόύϋΰώ
A'E'I'I:I:'O'Y'Y:Y:'V': ΆΈΊΪΪΌΎΫΫΏ
])
AT_CLEANUP

AT_SETUP([Casemap])
AT_KEYWORDS([casemap])

AT_CHECK([DICOD_TEST "glv'ssa" -- casemap=upper],
[0],
[glv'ssa: ΓΛΏΣΣΑ
])

AT_CHECK([DICOD_TEST "GLV'SSA" -- casemap=lower],
[0],
[GLV'SSA: γλώσσα
])

AT_CHECK([DICOD_TEST "Glv'ssa" :grup "Glv'ssa" :grlo "Glv'ssa" -- grup casemap=upper grlo casemap=lower],
[0],
[Glv'ssa: Γλώσσα
Glv'ssa: ΓΛΏΣΣΑ
Glv'ssa: γλώσσα
])
AT_CLEANUP

m4_popdef([DICOD_TEST])
